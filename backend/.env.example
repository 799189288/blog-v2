# Server
BIND_ADDR=0.0.0.0:8088

# Postgres
DATABASE_URL=postgres://blog:blog@localhost:5435/blog

# JWT secret (change for production - use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

# CORS (comma-separated origins; use * for dev only)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180

# Static assets directory for SPA (relative to the binary's CWD).
# Leave empty in development; set to ../frontend/dist for production.
STATIC_DIR=

# Public site identity — used to build absolute URLs in /rss.xml and
# /sitemap.xml, and as channel metadata in the RSS feed.
SITE_URL=http://localhost:5173
SITE_TITLE=Blog
SITE_DESCRIPTION=Personal blog

# Image uploads (admin /api/admin/uploads).
# UPLOAD_DIR is created on startup if missing. Served at /uploads/<file>.
# The SPA dev servers proxy /uploads to this backend, and in production a
# reverse proxy does the same — so URLs returned to the editor stay
# relative and survive moving between origins.
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=5242880

# Comment spam: comma-separated case-insensitive substrings. Any match
# against name + email + body routes the new comment to status='spam'
# instead of 'pending'. Leave blank to disable.
COMMENT_BLOCKLIST=

# Comment-notification email (optional). All three of SMTP_HOST,
# SMTP_FROM, SMTP_TO must be set to enable; otherwise notifications are
# silently disabled. STARTTLS (port 587) is the default; set
# SMTP_STARTTLS=false for implicit TLS on port 465. Username/password are
# blank for unauthenticated relays.
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Logging
RUST_LOG=info,blog_backend=debug,tower_http=info
